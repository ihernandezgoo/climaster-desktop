<Window x:Class="Climaster_feature.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Climaster_feature"
        xmlns:vm="clr-namespace:Climaster_feature.ViewModels"
        xmlns:conv="clr-namespace:Climaster_feature.Converters"
        xmlns:views="clr-namespace:Climaster_feature.Views"
        xmlns:res="clr-namespace:Climaster_feature.Resources"
        mc:Ignorable="d"
        Title="{x:Static res:Strings.AppTitle}" 
        Height="850" 
        Width="1750"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117">
    
    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>
    
    <Window.Resources>
        <conv:HexToColorConverter x:Key="HexToColorConverter"/>
        <conv:ElementTypeToDisplayNameConverter x:Key="ElementTypeConverter"/>
        <conv:PercentageToWidthConverter x:Key="PercentageToWidthConverter"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <conv:NullToBoolConverter x:Key="NullToBoolConverter"/>
        
        <!-- Glassmorphism Button Style (SIN blur) -->
        <Style x:Key="GlassButton" TargetType="Button">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#33FFFFFF" Offset="0"/>
                        <GradientStop Color="#22FFFFFF" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <SolidColorBrush Color="#4CAF50" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"
                                            TextBlock.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#554CAF50" Offset="0"/>
                                            <GradientStop Color="#4400BCD4" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                                <Setter Property="BorderBrush">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#4CAF50" Opacity="0.6"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <SolidColorBrush Color="#224CAF50"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Action Button Styles -->
        <Style x:Key="GreenButton" TargetType="Button" BasedOn="{StaticResource GlassButton}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#554CAF50" Offset="0"/>
                        <GradientStop Color="#4400E676" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <SolidColorBrush Color="#4CAF50" Opacity="0.5"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BlueButton" TargetType="Button" BasedOn="{StaticResource GlassButton}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#552196F3" Offset="0"/>
                        <GradientStop Color="#4400BCD4" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <SolidColorBrush Color="#2196F3" Opacity="0.5"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RedButton" TargetType="Button" BasedOn="{StaticResource GlassButton}">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#55F44336" Offset="0"/>
                        <GradientStop Color="#44FF5252" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <SolidColorBrush Color="#F44336" Opacity="0.5"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Glass Panel Style -->
        <Style x:Key="GlassPanel" TargetType="Border">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#1C2128" Offset="0"/>
                        <GradientStop Color="#161B22" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#334CAF50" Offset="0"/>
                        <GradientStop Color="#3300BCD4" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="20"/>
        </Style>

        <!-- TextBox Style -->
        <Style x:Key="GlassTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="#0A0E27"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <SolidColorBrush Color="White" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                        Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox Style -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#161B22"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#4CAF50"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                        Grid.Column="2"
                                        Focusable="false"
                                        IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                        ClickMode="Press"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}"
                                              BorderBrush="{TemplateBinding BorderBrush}"
                                              BorderThickness="{TemplateBinding BorderThickness}"
                                              CornerRadius="8">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                </Grid.ColumnDefinitions>
                                                <Path x:Name="Arrow"
                                                    Grid.Column="1"
                                                    HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Data="M 0 0 L 4 4 L 8 0 Z"
                                                    Fill="#4CAF50"/>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter Name="ContentSite"
                                            IsHitTestVisible="False"
                                            Content="{TemplateBinding SelectionBoxItem}"
                                            ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                            ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                            Margin="10,5"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Left"/>
                            <Popup Name="Popup"
                                 Placement="Bottom"
                                 IsOpen="{TemplateBinding IsDropDownOpen}"
                                 AllowsTransparency="True"
                                 Focusable="False"
                                 PopupAnimation="Slide">
                                <Grid Name="DropDown"
                                    SnapsToDevicePixels="True"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                          Background="#1C2128"
                                          BorderBrush="#4CAF50"
                                          BorderThickness="1"
                                          CornerRadius="8"
                                          Margin="0,5,0,0">
                                        <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBoxItem Style -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1C2128"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Name="Border"
                              Background="{TemplateBinding Background}"
                              BorderThickness="0"
                              CornerRadius="6"
                              Padding="{TemplateBinding Padding}"
                              Margin="2">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#2C3640"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#334CAF50"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="450"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL: Configuration -->
        <Border Grid.Column="0" Style="{StaticResource GlassPanel}" Margin="0,0,10,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="{x:Static res:Strings.Configuration}" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="White" 
                               Margin="0,0,0,15"/>

                    <!-- Widget ID -->
                    <TextBlock Text="{x:Static res:Strings.WidgetId}" Foreground="#B0B0B0" FontSize="11" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding WidgetId, UpdateSourceTrigger=PropertyChanged}" 
                             Style="{StaticResource GlassTextBox}"
                             Margin="0,0,0,12"/>

                    <!-- Widget Size Selector -->
                    <TextBlock Text="{x:Static res:Strings.WidgetSize}" Foreground="#B0B0B0" FontSize="11" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding AvailableSizes}"
                             SelectedItem="{Binding SelectedSize}"
                             Margin="0,0,0,8">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}" 
                                              FontWeight="SemiBold"
                                              Foreground="White"
                                              FontSize="13"/>
                                    <TextBlock Text="{Binding Description}" 
                                              FontSize="10"
                                              Foreground="#B0B0B0"
                                              TextWrapping="Wrap"
                                              Margin="0,2,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <!-- Size Info Panel -->
                    <Border Background="#1A2332"
                            BorderBrush="{Binding SpaceStatusColor}"
                            BorderThickness="2"
                            CornerRadius="12"
                            Padding="12"
                            Margin="0,0,0,15">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,8">
                                <TextBlock Text="📏 " 
                                          FontSize="16"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding CurrentSizeInfo}"
                                          Foreground="#00BCD4"
                                          FontSize="14"
                                          FontWeight="Bold"
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <Separator Background="#33FFFFFF" Margin="0,0,0,8"/>
                            
                            <!-- Progress Bar de Espacio -->
                            <Grid Margin="0,0,0,8">
                                <Border Background="#2A2A2A"
                                        CornerRadius="10"
                                        Height="20"/>
                                <Border Background="{Binding SpaceStatusColor}"
                                        CornerRadius="10"
                                        Height="20"
                                        HorizontalAlignment="Left">
                                    <Border.Width>
                                        <MultiBinding Converter="{StaticResource PercentageToWidthConverter}">
                                            <Binding Path="UsedSpacePercentage"/>
                                            <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth"/>
                                        </MultiBinding>
                                    </Border.Width>
                                </Border>
                                <TextBlock Text="{Binding UsedSpacePercentage, StringFormat={}{0:0}%}"
                                          Foreground="White"
                                          FontSize="10"
                                          FontWeight="Bold"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                            </Grid>
                            
                            <TextBlock Text="{Binding MaxElementsInfo}"
                                      Foreground="#B0B0B0"
                                      FontSize="10"
                                      HorizontalAlignment="Center"
                                      Margin="0,0,0,3"/>
                            
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="Erabilitakoa"
                                              Foreground="#B0B0B0"
                                              FontSize="9"
                                              HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Path=LayoutElements.Count, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue=0}"
                                              Foreground="{Binding SpaceStatusColor}"
                                              FontSize="16"
                                              FontWeight="Bold"
                                              HorizontalAlignment="Center"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <TextBlock Text="Geratzen dira"
                                              Foreground="#B0B0B0"
                                              FontSize="9"
                                              HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding RemainingSpace}"
                                              Foreground="#4CAF50"
                                              FontSize="16"
                                              FontWeight="Bold"
                                              HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                            
                            <Separator Background="#33FFFFFF" Margin="0,0,0,8"/>
                            
                            <TextBlock Text="💡 Gomendatutakoak:"
                                      Foreground="#FF9800"
                                      FontSize="10"
                                      FontWeight="Bold"
                                      Margin="0,0,0,5"/>
                            
                            <TextBlock Text="{Binding RecommendedElementsInfo}"
                                      Foreground="#FFC107"
                                      FontSize="9"
                                      TextWrapping="Wrap"
                                      LineHeight="15"/>
                        </StackPanel>
                    </Border>

                    <!-- Background Color -->
                    <TextBlock Text="{x:Static res:Strings.BackgroundColor}" Foreground="#B0B0B0" FontSize="11" Margin="0,0,0,5"/>
                    
                    <!-- Color Picker Visual -->
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox Grid.Column="0"
                                Text="{Binding BackgroundColor, UpdateSourceTrigger=PropertyChanged}" 
                                Style="{StaticResource GlassTextBox}"
                                Margin="0,0,5,0"/>
                        
                        <!-- Color Preview -->
                        <Border Grid.Column="1"
                                Background="{Binding BackgroundColor, Converter={StaticResource HexToColorConverter}}"
                                BorderBrush="#FFFFFF"
                                BorderThickness="2"
                                CornerRadius="8"
                                Height="40"/>
                    </Grid>

                    <!-- Base Color (without opacity) -->
                    <TextBlock Text="Oinarrizko Kolorea:" Foreground="#B0B0B0" FontSize="11" Margin="0,0,0,5"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBox Grid.Column="0"
                                Text="{Binding BaseColor, UpdateSourceTrigger=PropertyChanged}" 
                                Style="{StaticResource GlassTextBox}"
                                Margin="0,0,5,0"
                                ToolTip="Color sin transparencia (ej: #FFFFFF)"/>
                        
                        <!-- Color Preview -->
                        <Border Grid.Column="1"
                                Background="{Binding BaseColor, Converter={StaticResource HexToColorConverter}}"
                                BorderBrush="#FFFFFF"
                                BorderThickness="2"
                                CornerRadius="8"
                                Height="40"/>
                    </Grid>

                    <!-- Opacity Control -->
                    <TextBlock Text="Gardentasuna (Opacity):" Foreground="#B0B0B0" FontSize="11" Margin="0,0,0,5"/>
                    <Grid Margin="0,0,0,8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Slider Grid.Row="0"
                                Value="{Binding BackgroundOpacity, UpdateSourceTrigger=PropertyChanged}" 
                                Minimum="0" 
                                Maximum="100" 
                                TickFrequency="5" 
                                IsSnapToTickEnabled="True"
                                Margin="0,0,0,5"
                                ToolTip="0% = Guztiz gardena, 100% = Opakua"/>
                        
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0"
                                      Text="🔲 Gardena" 
                                      Foreground="#888" 
                                      FontSize="9" 
                                      HorizontalAlignment="Left"/>
                            
                            <TextBlock Grid.Column="1"
                                      Text="{Binding OpacityPercentage}" 
                                      Foreground="#4CAF50" 
                                      FontSize="12" 
                                      FontWeight="Bold"
                                      HorizontalAlignment="Center"/>
                            
                            <TextBlock Grid.Column="2"
                                      Text="⬛ Opakua" 
                                      Foreground="#FFF" 
                                      FontSize="9" 
                                      HorizontalAlignment="Right"/>
                        </Grid>
                    </Grid>

                    <!-- Predefined Colors -->
                    <TextBlock Text="Koloreak:" Foreground="#B0B0B0" FontSize="10" Margin="0,0,0,5"/>
                    <ItemsControl ItemsSource="{Binding PredefinedColors}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Width="30" 
                                        Height="30"
                                        Margin="2"
                                        Background="{Binding Converter={StaticResource HexToColorConverter}}"
                                        BorderBrush="#FFFFFF"
                                        BorderThickness="1"
                                        Command="{Binding DataContext.SelectElementCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        Click="ColorButton_Click"
                                        Tag="{Binding}"
                                        Cursor="Hand"
                                        ToolTip="{Binding}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="6"
                                                    Cursor="{TemplateBinding Cursor}"/>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    
                    <Separator Background="#33FFFFFF" Margin="0,12,0,12"/>

                    <!-- Corner Radius -->
                    <TextBlock Text="{x:Static res:Strings.CornerRadius}" Foreground="#B0B0B0" FontSize="11" Margin="0,0,0,5"/>
                    <Slider Value="{Binding CornerRadius}" 
                            Minimum="0" 
                            Maximum="50" 
                            TickFrequency="1" 
                            IsSnapToTickEnabled="True"
                            Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding CornerRadius, StringFormat={}{0:px}}" 
                               Foreground="White" 
                               FontSize="12" 
                               HorizontalAlignment="Center"
                               Margin="0,0,0,15"/>

                    <!-- Add Elements Section -->
                    <TextBlock Text="{x:Static res:Strings.AddElements}" 
                               FontSize="14" 
                               FontWeight="Bold" 
                               Foreground="White" 
                               Margin="0,0,0,8"/>

                    <Button Content="{x:Static res:Strings.LocationName}" 
                            Style="{StaticResource GlassButton}"
                            Command="{Binding AddElementCommand}"
                            CommandParameter="location_name"
                            IsEnabled="{Binding CanAddMoreElements}"
                            Margin="0,0,0,6"/>

                    <Button Content="{x:Static res:Strings.Temperature}" 
                            Style="{StaticResource GlassButton}"
                            Command="{Binding AddElementCommand}"
                            CommandParameter="current_temp"
                            IsEnabled="{Binding CanAddMoreElements}"
                            Margin="0,0,0,6"/>

                    <Button Content="{x:Static res:Strings.Condition}" 
                            Style="{StaticResource GlassButton}"
                            Command="{Binding AddElementCommand}"
                            CommandParameter="current_condition_text"
                            IsEnabled="{Binding CanAddMoreElements}"
                            Margin="0,0,0,6"/>

                    <Button Content="{x:Static res:Strings.Humidity}" 
                            Style="{StaticResource GlassButton}"
                            Command="{Binding AddElementCommand}"
                            CommandParameter="humidity"
                            IsEnabled="{Binding CanAddMoreElements}"
                            Margin="0,0,0,6"/>

                    <Button Content="{x:Static res:Strings.Wind}" 
                            Style="{StaticResource GlassButton}"
                            Command="{Binding AddElementCommand}"
                            CommandParameter="wind_speed"
                            IsEnabled="{Binding CanAddMoreElements}"
                            Margin="0,0,0,6"/>

                    <Button Content="{x:Static res:Strings.Divider}" 
                            Style="{StaticResource GlassButton}"
                            Command="{Binding AddElementCommand}"
                            CommandParameter="horizontal_divider"
                            IsEnabled="{Binding CanAddMoreElements}"
                            Margin="0,0,0,6"/>

                    <Button Content="{x:Static res:Strings.DailyForecast}" 
                            Style="{StaticResource GlassButton}"
                            Command="{Binding AddElementCommand}"
                            CommandParameter="daily_forecast_row"
                            IsEnabled="{Binding CanAddMoreElements}"
                            Margin="0,0,0,15"/>

                    <!-- Actions -->
                    <Separator Background="#33FFFFFF" Margin="0,0,0,15"/>

                    <TextBlock Text="{x:Static res:Strings.ExportWidget}" 
                               FontSize="12" 
                               FontWeight="Bold" 
                               Foreground="#888" 
                               Margin="0,0,0,8"/>

                    <Button Content="{x:Static res:Strings.SaveJson}" 
                            Style="{StaticResource GreenButton}"
                            Command="{Binding SaveJsonCommand}"
                            Margin="0,0,0,6"/>

                    <Button Content="{x:Static res:Strings.GenerateQR}" 
                            Style="{StaticResource GreenButton}"
                            Command="{Binding GenerateQRCommand}"
                            Margin="0,0,0,15"
                            ToolTip="{x:Static res:Strings.TooltipGenerateQR}"/>

                  
                  
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- CENTER PANEL: Layout Editor -->
        <Border Grid.Column="1" Style="{StaticResource GlassPanel}" Margin="5,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="{x:Static res:Strings.LayoutElements}" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           Margin="0,0,0,15"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding LayoutElements}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#0A0E27" 
                                        BorderBrush="#33FFFFFF" 
                                        BorderThickness="1" 
                                        CornerRadius="12" 
                                        Padding="12" 
                                        Margin="0,0,0,8"
                                        MouseLeftButtonDown="ElementBorder_Click"
                                        Tag="{Binding}"
                                        Cursor="Hand">
                                    
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Información del elemento -->
                                        <StackPanel Grid.Row="0" Grid.Column="0">
                                            <TextBlock Text="{Binding Type, Converter={StaticResource ElementTypeConverter}}" 
                                                       Foreground="White" 
                                                       FontSize="14" 
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,5"/>
                                            

                                            <StackPanel Orientation="Horizontal" 
                                                        Visibility="{Binding FontSize, Converter={StaticResource NullToVisibilityConverter}}">
                                                <TextBlock Text="{x:Static res:Strings.FontSize}" Foreground="#B0B0B0" FontSize="11" Margin="0,0,3,0"/>
                                                <TextBlock Text="{Binding FontSize}" Foreground="#4CAF50" FontSize="11" FontWeight="SemiBold"/>
                                            </StackPanel>

                                            <StackPanel Orientation="Horizontal" 
                                                        Visibility="{Binding Days, Converter={StaticResource NullToVisibilityConverter}}">
                                                <TextBlock Text="{x:Static res:Strings.Days}" Foreground="#B0B0B0" FontSize="11" Margin="0,0,3,0"/>
                                                <TextBlock Text="{Binding Days}" Foreground="#FFC107" FontSize="11" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Botones de acción -->
                                        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="✏️" 
                                                    Width="35" 
                                                    Height="35"
                                                    Style="{StaticResource GlassButton}"
                                                    Command="{Binding DataContext.SelectElementCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="0,0,4,0"
                                                    ToolTip="Editatu"/>
                                            
                                            <Button Content="⬆️" 
                                                    Width="35" 
                                                    Height="35"
                                                    Style="{StaticResource GlassButton}"
                                                    Command="{Binding DataContext.MoveUpCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="0,0,4,0"/>
                                            
                                            <Button Content="⬇️" 
                                                    Width="35" 
                                                    Height="35"
                                                    Style="{StaticResource GlassButton}"
                                                    Command="{Binding DataContext.MoveDownCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="0,0,4,0"/>
                                            
                                            <Button Content="🗑️" 
                                                    Width="35" 
                                                    Height="35"
                                                    Style="{StaticResource RedButton}"
                                                    Command="{Binding DataContext.RemoveElementCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>

                                        <!-- Panel de edición expandible -->
                                        <Border Grid.Row="1" 
                                                Grid.Column="0" 
                                                Grid.ColumnSpan="2"
                                                Background="#0D1117"
                                                BorderBrush="#4CAF50"
                                                BorderThickness="1,0,1,1"
                                                CornerRadius="0,0,8,8"
                                                Padding="10"
                                                Margin="0,8,0,0"
                                                x:Name="EditPanel">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <TextBlock Text="⚙️ Propietateak"
                                                          Foreground="#4CAF50"
                                                          FontSize="11"
                                                          FontWeight="Bold"
                                                          Margin="0,0,0,8"/>

                                                <!-- Font Size Editor -->
                                                <StackPanel Visibility="{Binding HasFontSize, Converter={StaticResource BoolToVisibilityConverter}}"
                                                           Margin="0,0,0,8">
                                                    <TextBlock Text="Letra tamaina:" Foreground="#B0B0B0" FontSize="10" Margin="0,0,0,4"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="50"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Slider Grid.Column="0"
                                                                Value="{Binding FontSize, Mode=TwoWay}"
                                                                Minimum="8"
                                                                Maximum="72"
                                                                TickFrequency="1"
                                                                IsSnapToTickEnabled="True"
                                                                Margin="0,0,8,0"/>
                                                        <TextBlock Grid.Column="1"
                                                                  Text="{Binding FontSize, StringFormat={}{0}px}"
                                                                  Foreground="White"
                                                                  FontSize="11"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Center"/>
                                                    </Grid>
                                                </StackPanel>

                                                <!-- Days Editor -->
                                                <StackPanel Visibility="{Binding HasDays, Converter={StaticResource BoolToVisibilityConverter}}"
                                                           Margin="0,0,0,8">
                                                    <TextBlock Text="Egunak:" Foreground="#B0B0B0" FontSize="10" Margin="0,0,0,4"/>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="50"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Slider Grid.Column="0"
                                                                Value="{Binding Days, Mode=TwoWay}"
                                                                Minimum="1"
                                                                Maximum="7"
                                                                TickFrequency="1"
                                                                IsSnapToTickEnabled="True"
                                                                Margin="0,0,8,0"/>
                                                        <TextBlock Grid.Column="1"
                                                                  Text="{Binding Days}"
                                                                  Foreground="White"
                                                                  FontSize="11"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Center"/>
                                                    </Grid>
                                                </StackPanel>
                                                
                                                <!-- Alignment Info (Locked to Center) -->
                                                <Border Background="#1A2332"
                                                        BorderBrush="#4CAF50"
                                                        BorderThickness="1"
                                                        CornerRadius="8"
                                                        Padding="8"
                                                        Margin="0,0,0,8">
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <TextBlock Text="📍" 
                                                                  FontSize="12"
                                                                  VerticalAlignment="Center"
                                                                  Margin="0,0,5,0"/>
                                                        <TextBlock Text="Lerrokatzea: Zentratuta" 
                                                                  Foreground="#4CAF50" 
                                                                  FontSize="10"
                                                                  FontWeight="SemiBold"
                                                                  VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ANDROID PREVIEW PANEL -->
        <Border Grid.Column="2" Style="{StaticResource GlassPanel}" Margin="5,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="{x:Static res:Strings.AndroidPreview}" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           Margin="0,0,0,15"/>

                <!-- Phone Frame -->
                <Border Grid.Row="1" 
                        Background="#1E1E1E" 
                        CornerRadius="30" 
                        Padding="10"
                        BorderBrush="#444"
                        BorderThickness="3">
                    <Grid>
                        <!-- Status Bar -->
                        <Border VerticalAlignment="Top" 
                                Height="25" 
                                Background="#0A0E27"
                                CornerRadius="15,15,0,0"
                                Margin="0,0,0,5">
                            <Grid>
                                <TextBlock Text="12:30" 
                                          Foreground="White" 
                                          FontSize="10" 
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                                <StackPanel Orientation="Horizontal" 
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Margin="0,0,15,0">
                                    <TextBlock Text="📶" FontSize="10" Margin="0,0,5,0"/>
                                    <TextBlock Text="🔋" FontSize="10"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Widget Preview -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto" 
                                     Margin="0,35,0,0">
                            <views:AndroidWidgetPreview 
                                LayoutElements="{Binding LayoutElements}"
                                BackgroundColor="{Binding BackgroundColor}"
                                CornerRadiusValue="{Binding CornerRadius}"
                                Margin="10"/>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <TextBlock Grid.Row="2"
                          Text="{x:Static res:Strings.ApproximatePreview}"
                          Foreground="#888"
                          FontSize="10"
                          HorizontalAlignment="Center"
                          Margin="0,10,0,0"/>
            </Grid>
        </Border>

        <!-- RIGHT PANEL: QR Code + JSON Preview -->
        <Border Grid.Column="3" Style="{StaticResource GlassPanel}" Margin="10,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- QR Code Section -->
                <StackPanel Grid.Row="0">
                    <TextBlock Text="{x:Static res:Strings.QRCode}" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Foreground="White" 
                               Margin="0,0,0,10"/>

                    <Border Background="#0A0E27" 
                            BorderBrush="#33FFFFFF" 
                            BorderThickness="1" 
                            CornerRadius="12" 
                            Padding="15"
                            Height="240"
                            Margin="0,0,0,10">
                        <Grid>
                            <!-- Estado: Sin QR -->
                            <StackPanel VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Visibility="{Binding QRCodeImage, Converter={StaticResource NullToBoolConverter}}">
                                
                                <TextBlock Text="⏸️" FontSize="40" 
                                          Foreground="#666"
                                          HorizontalAlignment="Center"
                                          Margin="0,0,0,10"/>
                                <TextBlock Text="{x:Static res:Strings.NoQRCode}"
                                          Foreground="#666" 
                                          FontSize="14"
                                          FontWeight="SemiBold"
                                          HorizontalAlignment="Center"
                                          Margin="0,0,0,5"/>
                                <TextBlock Text="{x:Static res:Strings.UseGenerateButton}"
                                          Foreground="#888" 
                                          FontSize="11"
                                          TextAlignment="Center"
                                          HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Estado: Con QR -->
                            <StackPanel VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Visibility="{Binding QRCodeImage, Converter={StaticResource NullToVisibilityConverter}}">
                                
                                <Image Source="{Binding QRCodeImage}" 
                                      Width="180" 
                                      Height="180"
                                      Margin="0,0,0,10"
                                      Stretch="Uniform"/>
                                
                                <TextBlock Text="{x:Static res:Strings.ScanFromAndroid}" 
                                          Foreground="#4CAF50" 
                                          FontSize="11"
                                          FontWeight="SemiBold"
                                          HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Info del QR/Servidor -->
                    <Border Background="#0A0E27" 
                            BorderBrush="#33FFFFFF" 
                            BorderThickness="1" 
                            CornerRadius="8" 
                            Padding="10"
                            Margin="0,0,0,15"
                            Visibility="{Binding ServerUrl, Converter={StaticResource NullToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="📊 Información:" 
                                      Foreground="#4CAF50" 
                                      FontSize="10"
                                      FontWeight="Bold"
                                      Margin="0,0,0,5"/>
                            <TextBlock Text="{Binding ServerUrl}" 
                                      Foreground="#4CAF50" 
                                      FontSize="9" 
                                      TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- JSON Preview Section -->
                <TextBlock Grid.Row="1"
                          Text="{x:Static res:Strings.JsonPreview}" 
                           FontSize="16" 
                           FontWeight="Bold" 
                           Foreground="White" 
                           Margin="0,10,0,10"/>

                <Border Grid.Row="2" 
                        Background="#0A0E27" 
                        BorderBrush="#33FFFFFF" 
                        BorderThickness="1" 
                        CornerRadius="12" 
                        Padding="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding PreviewJson}" 
                                   Foreground="#4CAF50" 
                                   FontFamily="Consolas"
                                   FontSize="10"
                                   TextWrapping="Wrap"/>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
